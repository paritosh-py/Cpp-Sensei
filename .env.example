# Cpp-Sensei Backend Environment Variables
# Copy this file to '.env' and fill in your actual credentials.

# Your Google AI Studio Gemini API Key
# NEVER commit your actual API Key to version control or expose it in public repositories.
GEMINI_API_KEY=your_gemini_api_key_here

# The model to use. 'gemini-1.5-flash' is recommended for fast, cost-efficient, and accurate C++ assistance.
GEMINI_MODEL=gemini-1.5-flash

# Temperature settings (0.0 to 1.0). 0.4 is optimal for precise programming explanation tasks.
AI_TEMPERATURE=0.4

# Max tokens to generate per response to control response length and token consumption.
AI_MAX_OUTPUT_TOKENS=1024

# Server Host and Port settings for local and Electron integration execution.
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000
