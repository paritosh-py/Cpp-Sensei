{
  "name": "cpp-sensei",
  "version": "1.0.0",
  "description": "Sensei - The C++ Learning IDE",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "package": "npx electron-packager . Sensei --platform=win32 --arch=x64 --out=out --overwrite --icon=assets/icon.ico && copy dist\\server.exe out\\Sensei-win32-x64\\resources\\server.exe"
  },
  "keywords": [
    "c++",
    "ide",
    "education",
    "learning"
  ],
  "author": "Sensei Team",
  "license": "MIT",
  "devDependencies": {
    "electron": "^28.2.0",
    "electron-builder": "^24.9.1",
    "electron-packager": "^17.1.2"
  },
  "build": {
    "appId": "com.sensei.ide",
    "productName": "Sensei",
    "directories": {
      "output": "out"
    },
    "files": [
      "main.js",
      "preload.js",
      "index.html",
      "public/**/*",
      "assets/**/*"
    ],
    "extraResources": [
      {
        "from": "dist/server.exe",
        "to": "server.exe"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Sensei"
    }
  }
}
